# Supabase — browser-safe configuration (Phase B.02)
#
# Copy this file to `.env.local` (which is gitignored and never committed) and
# fill in the values from your Supabase project: Dashboard → Project Settings →
# API. Set the SAME two values in the Vercel project settings (Preview and
# Production environments).
#
# Both variables are PUBLIC on purpose — the URL and the *publishable* key are
# meant to reach the browser and are protected by Supabase Row-Level Security.
# Do NOT put any server-only secret here (no service-role key, no Sanity token);
# those are added server-side in a later phase and must never use NEXT_PUBLIC_.

NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

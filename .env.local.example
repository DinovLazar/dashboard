# ============================================================================
# Dashboard — environment variables (TEMPLATE; never commit real values)
#
# Copy this file to `.env.local` (gitignored, never committed) and fill in the
# values. The OPERATOR sets the real values — in `.env.local` for local work and
# in the Vercel project settings (Preview + Production) for deploys. The agent
# never creates or commits real values. This repo is PUBLIC: a leaked key here
# would be a real incident.
# ============================================================================

# --- Browser-safe Supabase config (B.02) -----------------------------------
# Both are PUBLIC on purpose — the URL and the *publishable* key are meant to
# reach the browser and are protected by Supabase Row-Level Security. Find them
# in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# --- Server-only secrets (B.03) ---------------------------------------------
# NEVER prefix these with NEXT_PUBLIC_, never send them to the browser, never
# log them, never commit them. Server code only.

# Supabase service-role key (Supabase → Project Settings → API → service_role).
# Lets server code read `client_secrets`, which RLS hides from every user.
# It bypasses Row-Level Security — treat it like a master key.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 32-byte key (base64) that encrypts per-client Sanity tokens at rest
# (AES-256-GCM). Generate with:  openssl rand -base64 32
# It lives ONLY here / in Vercel — never in the database. Lose it and the stored
# tokens cannot be decrypted; leak it AND the database and they can.
SANITY_TOKEN_ENC_KEY="your-32-byte-base64-key"

# --- B.03 verify script, local one-off (optional) ---------------------------
# Only needed to run `npm run verify:registry`, which signs in as the test user
# to prove RLS isolation. These are the test user's own login (Supabase →
# Authentication → Users). Not used by the app itself; safe to leave unset until
# you run the verify step.
TEST_USER_EMAIL="test-user@example.com"
TEST_USER_PASSWORD="the-test-user-password"
# Optional: lets `npm run seed:test-client` run without passing the UUID as an
# argument. Find it in Supabase → Authentication → Users (the "UID" column).
# TEST_USER_ID="00000000-0000-0000-0000-000000000000"
